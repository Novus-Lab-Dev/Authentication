    "start-api-key:server": "node api-key-auth/server/index.js",
    "start-api-key:client": "npm --prefix api-key-auth/client run dev",
    "start:session": "concurrently \"npm run start-session:server\" \"npm run start-session:client\"",
    "start-session:server": "node session-auth/server/index.js",
    "start-session:client": "npm --prefix session-auth/client run dev"
